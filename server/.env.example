# Copy this file to .env and change JWT_SECRET to your own random string.
PORT=4000
JWT_SECRET=change-this-to-a-long-random-string
MESSAGE_RETENTION_DAYS=30

# Only needed in production — set this to your deployed frontend's URL
# (e.g. https://your-site.netlify.app) so the backend only accepts
# requests from your real site. Leave unset for local development.
FRONTEND_URL=

# Creates your admin account automatically the first time the server
# starts (important for deploys, where the data folder starts empty).
# Once the account exists, these are ignored — safe to leave set.
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
